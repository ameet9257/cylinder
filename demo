        // Built with the user's proven GetFfbComputationType arrange (ELS + Index + GRTR +
        // IsEligibleForUpfrontCalculation) which returns a NON-Upfront type -> consumer skips.
        [Test]
        public void SafeProcess_WhenComputationTypeNotUpfront_ShouldSkipAndMarkProcessed()
        {
            // Arrange
            var instrumentConfig = InstrumentConfigs.GetInstrumentConfig("EquityLinkedSwap");
            var trade = instrumentConfig.CreateTradeModelPresenterWithTrade().Trade;
            trade.XOneReference = new XOneReference(500001, XOneReference.COD_APP_ELIOT) { Version = 1 };
            trade.ContractId = "ELI-500001";
            trade.TradeDate = XOneDate.Today;

            var underlying = new EliotUnderlying
            {
                UnderlyingName = "TEST_INDEX",
                UnderlyingType = EquityUnderlyingType.Index,
                UnderlyingId = 1
            };
            var els = new EquityLinkedSwap();
            els.ReturnLeg.Underlyer = new EquitySingleUnderlier
            {
                AssetId = underlying.UnderlyingId,
                UnderlyingType = underlying.UnderlyingType
            };
            trade.Product = els;

            if (trade.TradeAdditionalInformations is EquityOtcTradeInformations tradeInfo)
            {
                tradeInfo.IsLinkedToSecurity = true;
                tradeInfo.EquityEligibilityInformations = new List<EquityEligibilityInformation>
                {
                    new()
                    {
                        RegulatoryLaw = RegulatoryLaw.FFB,
                        RegulatoryCode = RegulatoryAuthority.DGFIP,
                        BusinessEligiblility = true,
                        SpecificAdditionalRegulatoryInformation =
                            new Ffb25RegulatoryReportingInformation { TaxStatusCode = "FFBSTDRAPP" }
                    }
                };
            }

            var eliotIndex = new EliotIndex
            {
                IndexName = underlying.UnderlyingName,
                IndexReturnType = "GRTR",
                UnderlyingId = underlying.UnderlyingId
            };
            instrumentConfig.MetaData = new Dictionary<string, IList<string>>
            {
                { EquityTradeHelper.IsEligibleForUpfrontCalculationMetaData, new List<string> { "true" } }
            };

            var message = CreateMessage(trade);
            var coreServiceMock = CreateCoreServiceMock(message);

            using var _ = MockData.Given(given =>
            {
                given.AllObjects(underlying);
                given.AllObjects(eliotIndex);
                given.ServiceMocks(coreServiceMock);
            });
            var consumer = BuildConsumer();

            // Act
            consumer.SafeProcess(message);

            // Assert
            coreServiceMock.Verify(
                s => s.MarkProcessingMessageAsProcessed(
                    message.Id, ConsumerName, It.IsAny<XOneDateTime>(), AssetClass.EQUITYOTC),
                Times.Once,
                "A non-Upfront computation type must be skipped and marked processed.");
        }

