        public void GetStockDividends_ShouldMapNetAndGrossFromSeededCorporateAction()
        {
            const string underlyingName = "TOTAL_X";
            SeedStockDividend("CA_TOTAL_DIV", underlyingName, net: 1.6d, gross: 2.0d);

