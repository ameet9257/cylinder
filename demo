        [Test]
        public void GetIndexDividends_ShouldMapEligibleAmountToNet_AndEligibleGrossToGross()
        {
            var rows = new[]
            {
                CreateUpfrontOnIndex("CAC40_X", eligibleAmount: 0.5d, eligibleGross: 0.7d),
                CreateUpfrontOnIndex("CAC40_X", eligibleAmount: 0.2d, eligibleGross: 0.3d),
            };

            var staticDataMock = NewStaticDataMock();
            staticDataMock
                .Setup(s => s.GetManyEquityFfbCorporateActionUpfrontForRangeOfDateOnIndex(
                    "CAC40_X", s_windowStart, s_windowEnd))
                .Returns(rows);

            List<EquityFfbUpfrontTaxComputationConsumer.UpfrontDividend> result;
            using (MockData.Given(g => g.AServiceMock(staticDataMock.Object)))
            {
                result = EquityFfbUpfrontTaxComputationConsumer
                    .GetIndexDividends("CAC40_X", s_windowStart, s_windowEnd).ToList();
            }

            Assert.That(result, Has.Count.EqualTo(2), nameof(result));
            Assert.That(result[0].NetAmount, Is.EqualTo(0.5d).Within(1E-9), "EligibleAmount -> NetAmount");
            Assert.That(result[0].GrossAmount, Is.EqualTo(0.7d).Within(1E-9), "EligibleGrossAmount -> GrossAmount");
            Assert.That(result[1].NetAmount, Is.EqualTo(0.2d).Within(1E-9), "EligibleAmount -> NetAmount");
        }

