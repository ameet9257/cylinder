        private static Trade BuildFfbTrade(EquityOption product, string contractId, bool businessEligible = true) =>
            new Trade
            {
                XOneReference = new XOneReference(AssetClass.EQUITYOTC, 12345) { Version = 1 },
                ContractId = contractId,
                TradeDate = XOneDate.Today,
                Product = product,
                TradeAdditionalInformations = new EquityOtcTradeInformations
                {
                    IsLinkedToSecurity = true,
                    RemainingQuantity = 100,
                    EquityEligibilityInformations = new List<EquityEligibilityInformation>
                    {
                        new()
                        {
                            RegulatoryLaw = RegulatoryLaw.FFB,
                            RegulatoryCode = RegulatoryAuthority.DGFIP,
                            BusinessEligiblility = businessEligible,
                            SpecificAdditionalRegulatoryInformation =
                                new Ffb25RegulatoryReportingInformation { TaxStatusCode = "DEFAULT" }
                        }
                    }
                }
            };

        private static Trade CreateFfbUpfrontEligibleTrade(
            string contractId = "ELI-300001",
            string underlyingName = "TOTAL_X",
            EquityUnderlyingType underlyingType = EquityUnderlyingType.Stock,
            double remainingQuantity = 100d,
            XOneDate? tradeDate = null,
            XOneDate? maturityDate = null,
            string taxStatusCode = "FFBSTDRAPP")
        {
            var option = new EquityOption("EquityOption")
            {
                Underlying = new EliotUnderlying
                {
                    UnderlyingName = underlyingName,
                    UnderlyingType = underlyingType,
                    UnderlyingIsActive = true
                }
            };
            option.ChangeMaturityDate(maturityDate ?? s_maturityDate);

            return new Trade
            {
                XOneReference = new XOneReference(AssetClass.EQUITYOTC, 300001) { Version = 1 },
                ContractId = contractId,
                TradeDate = tradeDate ?? s_tradeDate,
                Product = option,
                TradeAdditionalInformations = new EquityLinkedSwapTradeInformations
                {
                    IsLinkedToSecurity = true,
                    RemainingQuantity = remainingQuantity,
                    EquityEligibilityInformations = new List<EquityEligibilityInformation>
                    {
                        new EquityEligibilityInformation(RegulatoryLaw.FFB, RegulatoryAuthority.DGFIP)
                        {
                            BusinessEligiblility = true,
                            SpecificAdditionalRegulatoryInformation =
                                new Ffb25RegulatoryReportingInformation { TaxStatusCode = taxStatusCode }
                        }
                    }
                }
            };
        }
