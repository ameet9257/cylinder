        // =========================================================================================
        //  Helpers
        // =========================================================================================

        // ComputeUpfrontTax -> CalculateTax reads the WithholdingTax domain setting, which needs a
        // MockData.Given context (otherwise DomainSetting.get_Domain() subscribes to live NATS). This
        // runs the computation inside that context, mirroring your persistence test.
        private static (double totalTax, int count) ComputeInContext(
            EquityFfbUpfrontTaxComputationConsumer consumer,
            Trade trade,
            IReadOnlyList<EquityFfbUpfrontTaxComputationConsumer.UpfrontDividend> dividends)
        {
            using (MockData.Given(g => g.AnObject(CreateFfbPortfolio())))
            {
                return consumer.ComputeUpfrontTax(trade, dividends);
            }
        }

        private static IReadOnlyList<EquityFfbUpfrontTaxComputationConsumer.UpfrontDividend> Dividends(
            params (double net, double gross)[] items) =>
            items.Select(i => new EquityFfbUpfrontTaxComputationConsumer.UpfrontDividend(i.net, i.gross)).ToList();

        // Make the "EquityOption" instrument upfront-eligible. Mirrors EquityFFBHelperTest:
        // IsEligibleForUpfrontCalculation() reads MetaData; the config is fetched + mutated directly.
        private static void MakeEquityOptionUpfrontEligible()
        {
            var instrumentConfig = InstrumentConfigs.GetInstrumentConfig("EquityOption");
            instrumentConfig.AddMetaDataListValue(
                EquityTradeHelper.IsEligibleForUpfrontCalculationMetaData, "true");
        }

        // Stock seam: seed a cash dividend corporate action keyed by its id (feeds the stock stream).
        private static void SeedStockDividend(string caId, string underlyingName, double net, double gross)
        {
            var dividendCa = new EquityCorporateAction
            {
                CorporateActionId = caId,
                ApplicationDate = s_tradeDate.AddDays(10),
                Definition = new EquityDividend
                {
                    CorporateActionId = caId,
                    UnderlyingId = underlyingName,
                    NetAmount = net,
                    GrossAmount = gross,
                    CurrencyId = "EUR",
                    UpdateDate = s_tradeDate,
                },
            };

            EquityStaticDataServiceMock.CorporateActions[caId] = dividendCa;
        }

        // =========================================================================================
        //  Builders
        // =========================================================================================

        private static EliotUnderlying CreateEliotUnderlying(string name, EquityUnderlyingType type) =>
            new EliotUnderlying { UnderlyingName = name, UnderlyingType = type, UnderlyingIsActive = true };

        // GetFfbComputationType reads IndexReturnType: "STRD" -> Upfront, "GRTR" -> ExDate.
        private static EliotIndex CreateEliotIndex(string name, string indexReturnType) =>
            new EliotIndex { IndexName = name, IndexReturnType = indexReturnType };

        private static Trade CreateFfbUpfrontEligibleTrade(
            EliotUnderlying underlying,
            string contractId = "ELI-300001",
            double remainingQuantity = 100d,
            XOneDate? tradeDate = null,
            XOneDate? maturityDate = null,
            string taxStatusCode = "DEFAULT")
        {
            var option = new EquityOption("EquityOption") { Underlying = underlying };
            option.ChangeMaturityDate(maturityDate ?? s_maturityDate);

            return new Trade
            {
                XOneReference = new XOneReference(AssetClass.EQUITYOTC, 300001) { Version = 1 },
                ContractId = contractId,
                TradeDate = tradeDate ?? s_tradeDate,
                Product = option,
                TradeAdditionalInformations = new EquityOtcTradeInformations
                {
                    PortfolioId = FfbPortfolioName,
                    RemainingQuantity = remainingQuantity,
                    IsLinkedToSecurity = true,
                    EquityEligibilityInformations = new List<EquityEligibilityInformation>
                    {
                        new EquityEligibilityInformation
                        {
                            RegulatoryLaw = RegulatoryLaw.FFB,
                            RegulatoryCode = RegulatoryAuthority.DGFIP,
                            BusinessEligibility = true,
                            SpecificAdditionalRegulatoryInformation = new Ffb25RegulatoryReportingInformation
                            {
                                TaxStatusCode = taxStatusCode,
                            },
                        },
                    },
                },
            };
        }

        private static EliotThirdParty CreateFfbPortfolio() =>
            new EliotThirdParty
            {
                Name = FfbPortfolioName,
                Type = EliotThirdPartyType.Portfolio,
                Nationality = "FRA",
                IsActive = true,
            };

        // A trade with NO FFB regulatory info -> IsTradeTaxable returns false (reliable skip).
        private static Trade CreateNonTaxableTrade()
        {
            var option = new EquityOption("EquityOption")
            {
                Underlying = CreateEliotUnderlying("TOTAL_X", EquityUnderlyingType.Stock),
            };
            option.ChangeMaturityDate(s_maturityDate);

            return new Trade
            {
                XOneReference = new XOneReference(AssetClass.EQUITYOTC, 300002) { Version = 1 },
                ContractId = "ELI-300002",
                TradeDate = s_tradeDate,
                Product = option,
                TradeAdditionalInformations = new EquityOtcTradeInformations
                {
                    PortfolioId = FfbPortfolioName,
                    IsLinkedToSecurity = true,
                    RemainingQuantity = 100d,
                    EquityEligibilityInformations = new List<EquityEligibilityInformation>(),
                },
            };
        }

        // Real TradeMessage: the consumer reads the trade via tradeMessage.GetTrade(); built from a
        // TradeDescriptor (4-arg ctor).
        private static TradeMessage CreateTradeMessage(
            Trade trade, TradeMessageSource source = TradeMessageSource.SaveWithWorkflow)
        {
            var descriptor = new TradeDescriptor
            {
                XOneReference = trade.XOneReference,
                InstrumentName = "EquityOption",
                AssetClass = AssetClass.EQUITYOTC,
            };

            return new TradeMessage(trade, descriptor, null, source);
        }

        private static EquityFfbCorporateActionOnIndex CreateUpfrontOnIndex(
            string indexName, double eligibleAmount, double eligibleGross) =>
            new EquityFfbCorporateActionOnIndex
            {
                UnderlyierName = indexName,
                ExDate = s_tradeDate.AddDays(5),
                EligibleAmount = eligibleAmount,
                EligibleGrossAmount = eligibleGross,
                DividendCurrency = "EUR",
            };

        private static EquityBasket CreateBasket(
            string name, params (string assetId, EquityUnderlyingType type)[] components) =>
            new EquityBasket
            {
                BasketName = name,
                Components = components
                    .Select(c => new EquityBasketComponent { AssetId = c.assetId, Type = c.type })
                    .ToList(),
            };

        // A concrete non-TradeMessage used to exercise the "unsupported message type" guard.
        [Serializable]
        private sealed class DefaultMessageStub : DefaultMessage
        {
            private static int s_id;

            public DefaultMessageStub() : base(++s_id, XOneDateTime.Now) { }

            public override AssetClass AssetClass => AssetClass.EQUITYOTC;
        }
    }
