        // ===================================================================
        // HAPPY PATH - BASKET trade -> aggregated stock dividends -> processed
        // NOTE: your original version of this test used CreateValidFfbStockTrade(), whose
        // underlying is Stock - so FetchDividends would take the STOCK branch, NOT the basket
        // branch, and GetStockDividendFromBasket would never run. Fixed to use a basket trade.
        // ===================================================================
        [Test]
        public void SafeProcess_WhenFfbEligibleBasketTrade_ShouldAggregateStockComponentDividends()
        {
            // --- Arrange ---
            var trade = CreateValidFfbBasketTrade();
            var descriptor = CreateDescriptorFor(trade);
            var message = CreateMessage(trade, descriptor);

            var coreServiceMock = CreateCoreServiceMock(message);
            var tradeServiceMock = CreateTradeServiceMock(descriptor, trade);

            var basket = new EquityBasket
            {
                Components = new List<EquityBasketComponent>
                {
                    new EquityBasketComponent { AssetId = "STOCK_A", Type = EquityUnderlyingType.Stock },
                    new EquityBasketComponent { AssetId = "STOCK_B", Type = EquityUnderlyingType.Stock },
                    new EquityBasketComponent { AssetId = "STOCK_C", Type = EquityUnderlyingType.Index }
                }
            };

            var equityTradeServiceMock = new Mock<IEquityTradeService>(MockBehavior.Strict);
            equityTradeServiceMock
                .Setup(s => s.GetEquityBasketByName(It.IsAny<string>()))
                .Returns(basket)
                .Verifiable();

            // Basket path recurses into GetStockDividendsSafe, which streams - mock the streaming service.
            var streamingMock = new Mock<IEquityStaticDataStreamingService>(MockBehavior.Strict);
            streamingMock
                .Setup(s => s.StreamCorporateActionsDividendEstimated(
                    It.IsAny<string>(), It.IsAny<XOneDate>(), It.IsAny<XOneDate>()))
                .Returns(new RequestStream(System.Array.Empty<EquityCorporateAction>().AsStream()))
                .Verifiable();

            using var _ = MockData.Given(given => given
                .ServiceMocks(coreServiceMock, tradeServiceMock, equityTradeServiceMock, streamingMock));

            var consumer = new EquityFfbUpfrontTaxComputationConsumer(0);

            // --- Act ---
            consumer.SafeProcess(message);

            // --- Assert ---
            // Only the two STOCK components should trigger a dividend stream; the INDEX one is skipped.
            equityTradeServiceMock.Verify(s => s.GetEquityBasketByName(It.IsAny<string>()), Times.Once);
            streamingMock.Verify(s => s.StreamCorporateActionsDividendEstimated(
                It.IsAny<string>(), It.IsAny<XOneDate>(), It.IsAny<XOneDate>()), Times.Exactly(2));
        }

