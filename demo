        [Test]
        public void ComputeUpfrontTax_WithMultipleDividends_ShouldAggregateAmountsAndComputeTaxOnce()
        {
            var consumer = BuildConsumer();
            var trade = CreateFfbUpfrontEligibleTrade(
                CreateEliotUnderlying("UNKNOWN_RATE_STOCK_X", EquityUnderlyingType.Stock), remainingQuantity: 100d);

            var dividends = new List<EquityFfbUpfrontTaxComputationConsumer.UpfrontDividend>
            {
                new(5d, 8d),
                new(5d, 8d),
            };

            var (totalTax, count) = consumer.ComputeUpfrontTax(trade, dividends);

            const double expected = 100d * 1d * 1d * 10d; // min(net=10, gross=16) = 10
            Assert.That(count, Is.EqualTo(2), "Two dividends must produce count=2.");
            Assert.That(totalTax, Is.EqualTo(expected),
                "Dividends must be aggregated before tax is computed once on the total.");
        }

