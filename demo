// ============================================================================================
//  EquityFfbUpfrontTaxComputationConsumerTest
//
//  Matches HedgeBookingServiceConsumerTest conventions: [XOneTestFixture] + 4 [Category],
//  sealed class, strict Mock<>(MockBehavior.Strict), one behaviour per test, builders + mock
//  factories at the bottom.
//
//  Anchored to the CURRENT consumer (typed out by the user), no guessing:
//    Process(): not-TradeMessage -> Warn+return
//               var trade = tradeMessage.GetTrade();
//               var reference = trade.XOneReference;        // lock ref comes off the trade
//               lockToken = LockToken.ReserveToken(...); if null -> Warn+return
//               IsMessageProcessed(id, Name, AssetClass) == true -> Info+return     (3-arg)
//               MarkMessageAsProcessing(id, Name, AssetClass) != 1 -> Warn+return    (3-arg)
//               Check.ArgumentNotNull(trade); ProcessTrade(trade);
//               IsSuccess ? MarkProcessed : MarkErrored; catch -> MarkErrored; finally -> ReleaseToken
//    MarkProcessed -> MarkProcessingMessageAsProcessed(id, Name, XOneDateTime, AssetClass)  (4-arg)
//    MarkErrored   -> real interface MarkProcessingMessageAsErrored(long,string,XOneDateTime,
//                     AssetClass, ErroredMessage, string)                                   (6-arg)
//
//  Trade is carried ON the message: new TradeMessage(trade, descriptor, null, source) sets
//  _innerTrade, so tradeMessage.GetTrade() returns it WITHOUT any DB/cache/NATS call.
//
//  Tax formula: quantity * delta * pointValue * min(totalNet, totalGross); taxRate is a GATE
//  only (0 < r < 1). EquityEligibilityInformation property is the codebase spelling
//  "BusinessEligiblility" (confirmed by the compiler).
//
//  RUNTIME-CONFIRM (the only thing not provable offline): the 3 happy-path trades must return
//  FfbComputationType.Upfront so they reach the dividend fetch. No Upfront recipe was available,
//  so they use hand-built EquityOption trades (as in the original file). If one logs a skip or a
//  NATS "Invalid subject" error, rebuild that trade via InstrumentConfigs (like the not-Upfront
//  test) with an Upfront-yielding shape.
// ============================================================================================

