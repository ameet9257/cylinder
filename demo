                new List<EquityFfbUpfrontTaxComputationConsumer.UpfrontDividend>
                {
                    new(NetAmount: 10d, GrossAmount: 12d)
                });

            // Assert
            Assert.That(totalTax, Is.EqualTo(0d), "Zero remaining quantity must produce zero tax.");
            Assert.That(count, Is.EqualTo(1), "The dividend must still be counted.");
