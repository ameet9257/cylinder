        // -------------------------------------------------------------------
        // Shared builders / helpers
        // -------------------------------------------------------------------
        private static TradeDescriptor CreateDescriptorFor(Trade trade) =>
            new TradeDescriptor
            {
                XOneReference = trade.XOneReference,
                TradeDate = trade.TradeDate,
                InstrumentName = "EquityOption",
                AssetClass = AssetClass.EQUITYOTC
            };

        private static TradeMessage CreateMessage(Trade trade, TradeDescriptor descriptor) =>
            new TradeMessage(trade, descriptor, null, TradeMessageSource.DatabaseNotification);

        private static Mock<ICoreDirectoryService> CreateCoreServiceMock(TradeMessage message)
        {
            var mock = new Mock<ICoreDirectoryService>(MockBehavior.Strict);
            mock.Setup(s => s.IsMessageProcessed(message.Id, ConsumerName, AssetClass.EQUITYOTC))
                .Returns(false);
            mock.Setup(s => s.MarkMessageAsProcessing(message.Id, ConsumerName, AssetClass.EQUITYOTC))
                .Returns(1);
            mock.Setup(s => s.MarkProcessingMessageAsProcessed(
                    message.Id, ConsumerName, It.IsAny<XOneDateTime>(), AssetClass.EQUITYOTC))
                .Returns(1);
            return mock;
        }

        private static Mock<ITradeService> CreateTradeServiceMock(TradeDescriptor descriptor, Trade trade)
        {
            var mock = new Mock<ITradeService>(MockBehavior.Strict);
            mock.Setup(s => s.GetTradeDescriptor(It.IsAny<object>())).Returns(descriptor);
            mock.Setup(s => s.GetTradeByXOneReference(It.IsAny<XOneReference>())).Returns(trade);
            return mock;
        }

        private static Trade CreateValidFfbIndexTrade() =>
            CreateFfbIndexTradeWithMaturity(XOneDate.Today.AddMonths(1));

        private static Trade CreateFfbIndexTradeWithMaturity(XOneDate maturity)
        {
            var underlying = new EliotUnderlying
            {
                UnderlyingName = "CAC40_X",
                UnderlyingType = EquityUnderlyingType.Index,
                UnderlyingIsActive = true
            };

            var product = new EquityOption("EquityOption") { Underlying = underlying };
            product.ChangeMaturityDate(maturity);

            return BuildFfbTrade(product, 1679982017, "ELI-12345");
        }

