namespace Sgcib.TOne.EquityFfbUpfrontTaxComputationService
{
    public class EquityFfbUpfrontTaxComputationConsumer : StandardConsumer
    {
        public const string ConsumerName = "EquityFfbUpfrontTaxComputationServiceConsumer";

        public override string Name => ConsumerName;

        public readonly record struct UpfrontDividend(double NetAmount, double GrossAmount);

        public EquityFfbUpfrontTaxComputationConsumer(int threadCount)
            : base(threadCount)
        {
        }

        public override ILogHelper Logger => Log;

        private static LogHelper Log =>
            LogHelper.Get("Sgcib.TOne.EquityFFBUpfrontTaxComputationServiceConsumer");

        public override void RegisterSubjects()
        {
            RegisterSubject(PubSubConstants.Bus.TECHNICAL_EQUITYOTC, PubSubConstants.Subject.TRADE);
        }

        protected override void Process(DefaultMessage message)
        {
            if (message is not TradeMessage tradeMessage)
            {
                Logger.Warn($"Unsupported message type {message?.GetType().Name ?? "null"}");
                return;
            }

            LockToken lockToken = null;

            try
            {
                var tokenTradeReference = tradeMessage.TradeDescriptor.XOneReference;

                // 1) Claim the message first - cheap, no trade-service calls yet.
                // NOTE: verify tokenTradeReference?.ToContractId() resolves to the same id as trade.ContractId.
                lockToken = LockToken.ReserveToken(Name, tokenTradeReference?.ToContractId());
                if (lockToken == null)
                {
                    Logger.Warn($"Could not reserve lock for message {tradeMessage.Id}.");
                    return;
                }

                if (CoreServices.Directory.Current.IsMessageProcessed(tradeMessage.Id, Name, tradeMessage.AssetClass))
                {
                    Logger.Info($"Message {tradeMessage.Id} already processed.");
                    return;
                }

                if (CoreServices.Directory.Current.MarkMessageAsProcessing(tradeMessage.Id, Name, tradeMessage.AssetClass) != 1)
                {
                    Logger.Warn($"Could not mark message {tradeMessage.Id} as processing.");
                    return;
                }

                // 2) Only now extract the trade - we have claimed the message, so any
                //    error from here on marks the message as errored consistently.
                var descriptor = TradeServices.Trade.Current.GetTradeDescriptor(tradeMessage.AccessReference);
                Check.ArgumentNotNull(descriptor, nameof(descriptor));

                var trade = TradeServices.Trade.Current.GetTrade(descriptor);
                Check.ArgumentNotNull(trade, nameof(trade));

                var result = ProcessTrade(trade);

                if (result.IsSuccess)
                {
                    MarkProcessed(tradeMessage);
                }
                else
                {
                    MarkErrored(tradeMessage, result.ErrorMessage);
                }
            }
            catch (Exception ex)
            {
                Logger.Error($"Unexpected error for message {tradeMessage.Id}: {ex}");
                MarkErrored(tradeMessage, ex.Message);
            }
            finally
            {
                lockToken?.ReleaseToken();
            }
        }

        private TaxProcessingResult ProcessTrade(Trade trade)
        {
            if (!EquityFfbHelper.IsTradeTaxable(trade, out var reason))
            {
                Logger.Info($"Trade {trade.ContractId} skipped: {reason}");
                return TaxProcessingResult.Skip();
            }

            var computationType = EquityFfbHelper.GetFfbComputationType(trade, out var computationReason);
            if (computationType != FfbComputationType.Upfront)
            {
                Logger.Info($"Trade {trade.ContractId} skipped: {computationReason}");
                return TaxProcessingResult.Skip();
            }

            var underlying = EquityFfbHelper.GetTradeUnderlying(trade);
            if (underlying == null)
            {
                Logger.Info($"Trade {trade.ContractId}: underlying not found.");
                return TaxProcessingResult.Skip();
            }

            var startDate = trade.TradeDate.AddDays(1);
            var endDate = trade.Product?.MaturityDate ?? XOneDate.NULL_DATE;

            if (endDate.IsNull || startDate > endDate)
            {
                Logger.Info($"Trade {trade.ContractId}: invalid calculation period.");
                return TaxProcessingResult.Skip();
            }

            List<UpfrontDividend> dividends;

            try
            {
                dividends = FetchDividends(underlying, startDate, endDate);
            }
            catch (Exception ex)
            {
                return TaxProcessingResult.Error($"Dividend fetch failed: {ex.Message}");
            }

            if (dividends == null || dividends.Count == 0)
            {
                Logger.Info($"Trade {trade.ContractId}: no dividends.");
                return TaxProcessingResult.Skip();
            }

            var (tax, _) = ComputeUpfrontTax(trade, dividends);

            try
            {
                //SaveUpfrontTax(trade, tax); // DB persistence to be implemented
            }
            catch (Exception ex)
            {
                return TaxProcessingResult.Error($"Tax persistence failed: {ex.Message}");
            }

            Logger.Info($"Trade {trade.ContractId}: tax={tax:F2}");

            return TaxProcessingResult.Success();
        }

        private List<UpfrontDividend> FetchDividends(EliotUnderlying underlying, XOneDate start, XOneDate end)
        {
            return underlying.UnderlyingType switch
            {
                EquityUnderlyingType.Index  => GetIndexDividends(underlying.UnderlyingName, start, end),
                EquityUnderlyingType.Stock  => GetStockDividendsSafe(underlying.UnderlyingName, start, end),
                EquityUnderlyingType.Basket => GetStockDividendFromBasket(underlying, start, end),
                _ => new List<UpfrontDividend>()
            };
        }

        private void SaveUpfrontTax(Trade trade, double tax)
        {
            // TODO: Implement DB persistence
        }

        private void MarkProcessed(TradeMessage tradeMessage)
        {
            CoreServices.Directory.Current.MarkProcessingMessageAsProcessed(
                tradeMessage.Id,
                Name,
                XOneDateTime.Now,
                tradeMessage.AssetClass);

            ConsumerControlPanel.AddMonitoredEvent(MonitoredEvent.MessageProcessingSuccess);
        }

        private void MarkErrored(TradeMessage tradeMessage, string error)
        {
            ConsumerControlPanel.AddMonitoredEvent(MonitoredEvent.MessageProcessingFailure);

            CoreServices.Directory.Current.MarkProcessingMessageAsErrored(
                tradeMessage,
                Name,
                XOneDateTime.Now,
                error);
        }

        private class TaxProcessingResult
        {
            public bool IsSuccess { get; set; }
            public string ErrorMessage { get; set; }

            public static TaxProcessingResult Success() => new() { IsSuccess = true };
            public static TaxProcessingResult Skip()    => new() { IsSuccess = true };
            public static TaxProcessingResult Error(string msg) => new() { IsSuccess = false, ErrorMessage = msg };
        }

        public (double totalTax, int count) ComputeUpfrontTax(Trade trade, IReadOnlyList<UpfrontDividend> dividends)
        {
            double net = 0, gross = 0;

            foreach (var d in dividends)
            {
                net += d.NetAmount;
                gross += d.GrossAmount;
            }

            var tax = EquityFfbHelper.CalculateTax(trade, net, gross);
            return (tax, dividends.Count);
        }

        public static List<UpfrontDividend> GetIndexDividends(string name, XOneDate start, XOneDate end)
        {
            var list = EquityServices.StaticData.Current
                .GetManyEquityFfbCorporateActionUpfrontForRangeOfDateOnIndex(name, start, end);

            var result = new List<UpfrontDividend>(list.Count);

            foreach (var item in list)
            {
                result.Add(new UpfrontDividend(item.EligibleAmount, item.EligibleGrossAmount));
            }

            return result;
        }

        public static List<UpfrontDividend> GetStockDividendsSafe(string name, XOneDate start, XOneDate end)
        {
            var result = new List<UpfrontDividend>();

            var stream = new RpcClientStreamReaderWithErrors<EquityCorporateAction, CorruptedDataStream>(
                EquityServices.StaticDataStreaming.Current.StreamCorporateActionsDividendEstimated(name, start, end));

            foreach (var item in stream)
            {
                if (item?.Error != null)
                {
                    // Skip the corrupted item and keep going - one bad dividend
                    // must not fail the whole trade's tax computation.
                    Log.Warn($"Skipping corrupted dividend for {name}: {item.Error}");
                    continue;
                }

                var action = item.Object;
                if (action?.Definition is EquityDividend div)
                {
                    result.Add(new UpfrontDividend(div.NetAmount, div.GrossAmount));
                }
            }

            return result;
        }

        public static List<UpfrontDividend> GetStockDividendFromBasket(EliotUnderlying underlying, XOneDate start, XOneDate end)
        {
            var result = new List<UpfrontDividend>();
            var basket = EquityServices.Trade.Current.GetEquityBasketByName(underlying.UnderlyingName);

            foreach (var component in basket.Components)
            {
                if (component.Type == EquityUnderlyingType.Stock)
                {
                    result.AddRange(GetStockDividendsSafe(component.AssetId, start, end));
                }
            }

            return result;
        }
    }
}
